    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  let parsed;\n  try {\n    parsed = JSON.parse(item.json.text);\n  } catch(e) {\n    parsed = { sentimiento: 'neutro', puntuacion: 50, es_crisis: false };\n  }\n  \n  // Buscar el titulo e id_unico en el nodo Extraer Titulares\n  const extraer = $('Extraer Titulares').all();\n  const index = $input.all().indexOf(item);\n  const original = extraer[index] ? extraer[index].json : {};\n  \n  items.push({\n    json: {\n      titulo: original.titulo || '',\n      sentimiento: parsed.sentimiento,\n      puntuacion: parsed.puntuacion,\n      es_crisis: parsed.es_crisis,\n      id_unico: original.id_unico || ''\n    }\n  });\n}\n\nreturn items;"
      },
