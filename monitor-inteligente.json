    {
      "parameters": {
        "jsCode": "const channel = $input.first().json.rss.channel;\nconst posts = channel.item || [];\nconst items = [];\n\nfor (const post of posts.slice(0, 5)) {\n  items.push({\n    json: {\n      titulo: post.title,\n      link: post.link,\n      fecha: post.pubDate || '',\n      id_unico: post.link.substring(post.link.length - 20)\n    }\n  });\n}\n\nreturn items;"
      },
